{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build (Maven)",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean",
				"package",
				"-DskipTests"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run (JavaFX)",
			"type": "shell",
			"command": "mvn",
			"args": [
				"-q",
				"javafx:run"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		}
	]
}